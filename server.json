{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jors7/kadenzo-mcp",
  "description": "Schedule, manage, generate & analyze social posts across 11 networks from any AI agent.",
  "version": "1.3.1",
  "repository": {
    "url": "https://github.com/jors7/kadenzo-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "kadenzo-mcp",
      "version": "1.3.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Kadenzo API key from studio.kadenzo.app/dashboard/settings?section=api",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "KADENZO_API_KEY"
        }
      ]
    }
  ]
}
